# Domain
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
ENVIRONMENT=local

PROJECT_NAME=Platforma
STACK_NAME=platforma

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"
SECRET_KEY=change-me
FIRST_SUPERUSER=admin@platforma.example.com
FIRST_SUPERUSER_PASSWORD=change-me

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=platforma
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis / background jobs
REDIS_URL=redis://redis:6379/0

# Object storage
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET_MEDIA=media

# Auth
AUTH_PROVIDER=telegram
TG_BOT_TOKEN=
TG_BOT_USERNAME=
TG_WEBHOOK_SECRET=
BACKEND_INTERNAL_URL=http://backend:8000/api/v1
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=60

# AI
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
STT_PROVIDER=whisper_local
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

SENTRY_DSN=

# Docker images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
